{
  "schemaVersion": "0.2.0",
  "id": "ideomancer",
  "name": "Ideomancer",
  "version": "0.1.0",
  "summary": "Ideomancer manifest",
  "resources": [
    {
      "name": "Manifest",
      "kind": "consumable",
      "defaultMime": "application/vnd.map.manifest+json",
      "mimeTypes": [
        "application/vnd.map.manifest+json",
        "application/json"
      ],
      "schemaRef": "./schemas/manifest.schema.json",
      "description": "A document that defines a system at a high level"
    },
    {
      "name": "SystemMap",
      "kind": "consumable",
      "defaultMime": "application/vnd.map.graph+json",
      "mimeTypes": [
        "application/vnd.map.graph+json",
        "text/mermaid",
        "text/vnd.graphviz-dot"
      ],
      "schemaRef": "./schemas/system-map.schema.json"
    },
    {
      "name": "Watcher",
      "kind": "process",
      "schemaRef": "./schemas/watcher.schema.json"
    }
  ],
  "ops": [
    {
      "name": "manifest.create",
      "produces": [
        {
          "resource": "Manifest"
        }
      ]
    },
    {
      "name": "manifest.validate",
      "consumes": [
        {
          "resource": "Manifest"
        }
      ],
      "produces": [
        {
          "resource": "Manifest"
        }
      ]
    },
    {
      "name": "systemMap.generate",
      "consumes": [
        {
          "resource": "Manifest"
        }
      ],
      "produces": [
        {
          "resource": "SystemMap"
        }
      ]
    },
    {
      "name": "watcher.start",
      "produces": [
        {
          "resource": "Watcher"
        }
      ]
    }
  ],
  "events": [
    {
      "name": "map.generated",
      "payloadRef": "./schemas/events/map-generated.json"
    }
  ],
  "interfaces": {
    "cli": {
      "commands": [
        {
          "name": "manifest:init",
          "op": "manifest.create",
          "args": [
            {
              "name": "id",
              "type": "string",
              "required": false
            },
            {
              "name": "name",
              "type": "string",
              "required": true
            }
          ]
        },
        {
          "name": "manifest:validate",
          "op": "manifest.validate"
        },
        {
          "name": "generate:map",
          "op": "systemMap.generate",
          "args": [
            {
              "name": "format",
              "type": "string",
              "required": false
            }
          ]
        },
        {
          "name": "watcher:run",
          "op": "watcher.start"
        }
      ]
    }
  },
  "lore": {
    "epithet": "Shaper of Intent",
    "description": "Generated by ideomancer manifest:init on 2025-10-24T12:40:47-04:00"
  }
}
